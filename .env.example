# Azure Speech-to-Text (custom endpoint)
AZURE_SPEECH_KEY=your-key-here
AZURE_SPEECH_ENDPOINT=https://ai-summary-prod-speech.cognitiveservices.azure.com/

# HuggingFace token (required for gated models like Typhoon Whisper)
HF_TOKEN=hf_xxxxx

# OpenVINO device: GPU, CPU, or AUTO
OV_DEVICE=GPU

# OpenVINO model cache directory
OV_CACHE_DIR=./ov_cache
